{
  "name": "cekta/cli-symfony",
  "description": "adapter symfony/console to cekta",
  "type": "library",
  "license": "GPL-3.0-only",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "require": {
    "php": ">=8.2",
    "cekta/framework": "dev-master",
    "symfony/console": "^7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "@stable",
    "squizlabs/php_codesniffer": "@stable",
    "phpstan/phpstan": "@stable",
    "infection/infection": "@stable"
  },
  "scripts": {
    "test": [
      "@composer install",
      "@phpcs",
      "@phpstan",
      "@phpunit"
    ],
    "phpcs": "./vendor/bin/phpcs",
    "phpstan": "./vendor/bin/phpstan analyse --memory-limit=-1",
    "phpunit": "./vendor/bin/phpunit",
    "infection": "./vendor/bin/infection --show-mutations"
  },
  "autoload": {
    "psr-4": {
      "Cekta\\CliSymfony\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cekta\\CliSymfony\\Test\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Evgeniy Kuvshinov",
      "email": "smpl@itmywork.com"
    }
  ]
}
